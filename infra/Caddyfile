{
	# Global options
	email pedrolucho02@gmail.com
}

# Replace with your actual domain or DuckDNS subdomain
# For DuckDNS: actual-financas.duckdns.org
# For custom domain: finance.yourdomain.com
actual-financas.duckdns.org {
	reverse_proxy actual:5006

	# Security headers + COOP/COEP for SharedArrayBuffer (required by Actual Budget)
	header {
		Cross-Origin-Opener-Policy same-origin
		Cross-Origin-Embedder-Policy require-corp
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	# Gzip compression
	encode gzip

	# Access log
	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 3
		}
	}
}
