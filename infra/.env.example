# === Actual Budget Server Configuration ===

# Server port (internal, Caddy handles external)
ACTUAL_PORT=5006

# Data directory (mapped via Docker volume)
ACTUAL_DATA_DIR=/data

# === Authentication via Google OAuth2 ===
# Actual Budget has native OpenID/OAuth2 support.
# Configure Google as the identity provider.

ACTUAL_LOGIN_METHOD=openid
ACTUAL_OPENID_AUTH_METHOD=oauth2
ACTUAL_OPENID_PROVIDER_NAME=Google
ACTUAL_OPENID_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration

# Create OAuth2 credentials at:
# https://console.cloud.google.com/apis/credentials?project=actual-financas
# Type: Web application
# Authorized redirect URI: https://actual-financas.duckdns.org/openid/callback
ACTUAL_OPENID_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
ACTUAL_OPENID_CLIENT_SECRET=your-client-secret-here

# Must match the public URL where Actual is accessible
ACTUAL_OPENID_SERVER_HOSTNAME=https://actual-financas.duckdns.org

# Token never expires (for personal use)
ACTUAL_TOKEN_EXPIRATION=never
